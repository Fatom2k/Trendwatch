# TrendWatch — Environment Variables
# Copier ce fichier en .env et remplir les valeurs.
# Ne jamais committer .env en version control.

# =============================================================================
# Anthropic / Claude (requis pour la synthèse IA des tendances)
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# TikTok Creative Center
# =============================================================================
TIKTOK_API_KEY=your_tiktok_api_key_here
TIKTOK_COUNTRY_CODE=US
TIKTOK_TREND_PERIOD=7

# =============================================================================
# Instagram Graph API
# =============================================================================
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_USER_ID=your_instagram_business_user_id
INSTAGRAM_SEED_HASHTAGS=aesthetic,vintage,cottagecore

# SISTRIX (optionnel, enrichit les données hashtag Instagram)
SISTRIX_API_KEY=your_sistrix_api_key_here

# =============================================================================
# X / Twitter API v2
# =============================================================================
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_WOEID=1
TWITTER_LANGUAGE=en
TWITTER_SEED_KEYWORDS=aesthetic,trending,viral

# =============================================================================
# Exploding Topics
# =============================================================================
EXPLODING_TOPICS_API_KEY=your_exploding_topics_api_key_here
EXPLODING_TOPICS_LIMIT=50
EXPLODING_TOPICS_CATEGORY=

# =============================================================================
# Google Trends (pas de clé API requise, via pytrends)
# =============================================================================
GOOGLE_TRENDS_GEO=US
GOOGLE_TRENDS_LANGUAGE=en-US
GOOGLE_TRENDS_TZ_OFFSET=0
GOOGLE_TRENDS_KEYWORDS=aesthetic,cottagecore,darkacademia,y2k,minimalism

# =============================================================================
# Elasticsearch (single-node conteneurisé)
# =============================================================================
ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_INDEX=trendwatch_trends
ELASTICSEARCH_ENABLED=true

# =============================================================================
# Auth0 — Google OAuth (créer un compte sur https://auth0.com, gratuit)
# =============================================================================
# 1. Créer une Application → Regular Web Application
# 2. Connections > Social > activer Google
# 3. Allowed Callback URL : https://VOTRE_DOMAINE/auth/callback
# 4. Allowed Logout URL   : https://VOTRE_DOMAINE
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_CALLBACK_URL=https://yourdomain.com/auth/callback

# =============================================================================
# Session (générer une chaîne aléatoire de 32+ caractères)
# python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
SESSION_SECRET=generate_a_random_64char_hex_string_here

# =============================================================================
# Caddy / HTTPS — doit pointer vers l'IP de votre VPS
# =============================================================================
DOMAIN=yourdomain.com

# =============================================================================
# Agent & Scheduler
# =============================================================================
ACTIVE_PLATFORMS=google_trends,exploding_topics
SCHEDULE_CADENCE=daily
SCHEDULE_TIME=08:00
SCHEDULE_INTERVAL_HOURS=1
TIMEZONE=UTC
MIN_SCORE_THRESHOLD=30
OUTPUT_DIR=output/reports
