# TrendWatch — Environment Variables
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.

# =============================================================================
# Anthropic / Claude (required for AI summarization)
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# TikTok Creative Center
# =============================================================================
TIKTOK_API_KEY=your_tiktok_api_key_here
TIKTOK_COUNTRY_CODE=US
TIKTOK_TREND_PERIOD=7

# =============================================================================
# Instagram Graph API
# =============================================================================
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_USER_ID=your_instagram_business_user_id
INSTAGRAM_SEED_HASHTAGS=aesthetic,vintage,cottagecore

# SISTRIX (optional, enriches Instagram hashtag data)
SISTRIX_API_KEY=your_sistrix_api_key_here

# =============================================================================
# X / Twitter API v2
# =============================================================================
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_WOEID=1
TWITTER_LANGUAGE=en
TWITTER_SEED_KEYWORDS=aesthetic,trending,viral

# =============================================================================
# Exploding Topics
# =============================================================================
EXPLODING_TOPICS_API_KEY=your_exploding_topics_api_key_here
EXPLODING_TOPICS_LIMIT=50
EXPLODING_TOPICS_CATEGORY=

# =============================================================================
# Google Trends (no API key required, pytrends)
# =============================================================================
GOOGLE_TRENDS_GEO=US
GOOGLE_TRENDS_LANGUAGE=en-US
GOOGLE_TRENDS_TZ_OFFSET=0
GOOGLE_TRENDS_KEYWORDS=aesthetic,cottagecore,darkacademia,y2k,minimalism

# =============================================================================
# Agent & Scheduler
# =============================================================================
ACTIVE_PLATFORMS=google_trends,exploding_topics
SCHEDULE_CADENCE=daily
SCHEDULE_TIME=08:00
SCHEDULE_INTERVAL_HOURS=1
TIMEZONE=UTC
MIN_SCORE_THRESHOLD=30
OUTPUT_DIR=output/reports
