# TrendWatch — Variables d’environnement
# Copier ce fichier en .env et remplir les valeurs.
# Ne JAMAIS committer .env en version control.

# =============================================================================
# Domaine & SSL (Caddy gère Let’s Encrypt automatiquement)
# =============================================================================
DOMAIN=app.trendwatch2k10.com

# =============================================================================
# Auth0 — Google OAuth
# 1. Créer un compte sur https://auth0.com (gratuit)
# 2. Applications → Create Application → Regular Web Application
# 3. Authentication → Social → activer Google
# 4. Settings → Allowed Callback URLs : https://app.trendwatch2k10.com/auth/callback
# 5. Settings → Allowed Logout URLs    : https://app.trendwatch2k10.com
# =============================================================================
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_CALLBACK_URL=https://app.trendwatch2k10.com/auth/callback

# =============================================================================
# Accès & Rôles
# ADMIN_EMAILS  : peut voir ET ajouter des tendances
# ALLOWED_EMAILS: lecture seule (laisser vide = ouvert à tout compte Google authéntifié)
# Séparer les adresses par des virgules, sans espace
# =============================================================================
ADMIN_EMAILS=ton.email@gmail.com
ALLOWED_EMAILS=viewer1@gmail.com,viewer2@gmail.com

# =============================================================================
# Session cookie (générer avec : python3 -c "import secrets; print(secrets.token_hex(32))")
# =============================================================================
SESSION_SECRET=remplacer_par_une_chaine_aleatoire_64_chars

# =============================================================================
# Elasticsearch (single-node conteneurisé)
# =============================================================================
ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_INDEX=trendwatch_trends
ELASTICSEARCH_ENABLED=true

# =============================================================================
# Anthropic / Claude (requis pour la synthèse IA des tendances)
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# Plateformes de collecte
# =============================================================================
ACTIVE_PLATFORMS=google_trends,exploding_topics
GOOGLE_TRENDS_GEO=US
GOOGLE_TRENDS_LANGUAGE=en-US
GOOGLE_TRENDS_TZ_OFFSET=0
GOOGLE_TRENDS_KEYWORDS=aesthetic,cottagecore,darkacademia,y2k,minimalism

TIKTOK_API_KEY=
TIKTOK_COUNTRY_CODE=US
TIKTOK_TREND_PERIOD=7

INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_SEED_HASHTAGS=aesthetic,vintage,cottagecore
SISTRIX_API_KEY=

TWITTER_BEARER_TOKEN=
TWITTER_WOEID=1
TWITTER_LANGUAGE=en
TWITTER_SEED_KEYWORDS=aesthetic,trending,viral

EXPLODING_TOPICS_API_KEY=
EXPLODING_TOPICS_LIMIT=50
EXPLODING_TOPICS_CATEGORY=

# =============================================================================
# Déploiement automatique (scripts/auto-deploy.sh + systemd timer)
# dev  → surveille la branche "dev"
# prod → surveille la branche "main"
# =============================================================================
DEPLOY_TAG=dev

# =============================================================================
# Scheduler
# =============================================================================
SCHEDULE_CADENCE=daily
SCHEDULE_TIME=08:00
SCHEDULE_INTERVAL_HOURS=1
TIMEZONE=UTC
MIN_SCORE_THRESHOLD=30
OUTPUT_DIR=output/reports
